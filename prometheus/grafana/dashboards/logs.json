    {
      "type": "logs",
      "title": "All Errors",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 1 },
      "id": 2,
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=~\".+\", service_name!~\"loki|grafana|alloy\"} |~ \"(?i)error|fatal|panic\" != \"faultCode\" != \"bf-error-rate\" != \"faultCode\"",

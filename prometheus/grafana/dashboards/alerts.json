{
  "title": "EVtivity - Alerts",
  "uid": "evtivity-alerts",
  "tags": ["evtivity", "alerts"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "row",
      "title": "Active Alerts",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "alertlist",
      "title": "Firing / Pending alerts in EVtivity Alerts folder",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 1 },
      "id": 101,
      "options": {
        "viewMode": "list",
        "groupMode": "default",
        "sortOrder": 3,
        "showInstances": true,
        "maxItems": 50,
        "alertInstanceLabelFilter": "",
        "alertName": "",
        "folder": { "title": "EVtivity Alerts" },
        "stateFilter": {
          "firing": true,
          "pending": true,
          "noData": false,
          "normal": false,
          "error": true
        }
      }
    },
    {
      "type": "row",
      "title": "System Alert Metrics",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "id": 200,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "API 5xx Error Rate (alert ≥ 5%, critical)",
      "description": "sys-high-error-rate: ratio of 5xx responses to total requests over 5m, alerts if >5% for 5m",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 11 },
      "id": 201,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m])) * 100",
          "legendFormat": "5xx %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 5 }
            ]
          },
          "color": { "mode": "thresholds" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "thresholdsStyle": { "mode": "line+area" }
          }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "API p95 Request Latency (alert ≥ 2s, warning)",
      "description": "sys-high-request-latency: p95 of http_request_duration_seconds over 5m, alerts if >2s for 5m",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 11 },
      "id": 202,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 (s)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 }
            ]
          },
          "color": { "mode": "thresholds" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "thresholdsStyle": { "mode": "line+area" }
          }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "API Resident Memory (alert ≥ 450 MB, warning)",
      "description": "sys-high-memory-usage: process_resident_memory_bytes converted to MB, alerts if >450 MB for 5m",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 11 },
      "id": 203,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "RSS (MB)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 450 }
            ]
          },
          "color": { "mode": "thresholds" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "thresholdsStyle": { "mode": "line+area" }
          }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "OCPP Ping Success Rate (alert < 90%, warning)",
      "description": "sys-ocpp-ping-success-low: ocpp_ping_success_rate, alerts if <90% for 5m",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "id": 204,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "ocpp_ping_success_rate",
          "legendFormat": "success %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 90 }
            ]
          },
          "color": { "mode": "thresholds" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "thresholdsStyle": { "mode": "line+area" }
          }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "OCPP Connected Stations (alert < 1, critical)",
      "description": "sys-ocpp-no-connected-stations: ocpp_connected_stations, alerts if <1 for 10m",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "id": 205,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "ocpp_connected_stations",
          "legendFormat": "connected",
          "refId": "A"

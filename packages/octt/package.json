{
  "name": "@evtivity/octt",
  "version": "0.1.15",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "import": {
        "types": "./src/index.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "test": "vitest run --exclude src/__tests__/runner.test.ts",
    "run:all": "tsx src/cli.ts --server ws://localhost:7103",
    "run:1.6": "tsx src/cli.ts --server ws://localhost:7103 --version ocpp1.6",
    "run:2.1": "tsx src/cli.ts --server ws://localhost:7103 --version ocpp2.1",
    "run:cs": "tsx src/cs-cli.ts",
    "run:cs:2.1": "tsx src/cs-cli.ts --version ocpp2.1",
    "run:cs:1.6": "tsx src/cs-cli.ts --version ocpp1.6"
  },
  "dependencies": {
    "@evtivity/css": "*",
    "@evtivity/database": "*",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "tsx": "^4.19.2"
  }
}

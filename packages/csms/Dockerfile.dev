FROM node:24-slim AS build

WORKDIR /app

COPY package.json package-lock.json ./
COPY packages/lib/package.json packages/lib/
COPY packages/database/package.json packages/database/
COPY packages/api/package.json packages/api/
COPY packages/ocpp/package.json packages/ocpp/
COPY packages/ocpi/package.json packages/ocpi/
COPY packages/csms/package.json packages/csms/
COPY packages/portal/package.json packages/portal/
COPY packages/codegen/package.json packages/codegen/
COPY packages/css/package.json packages/css/
COPY packages/ocpi-simulator/package.json packages/ocpi-simulator/

RUN npm ci --ignore-scripts --workspace=packages/csms

COPY packages/csms/ packages/csms/
COPY packages/lib/ packages/lib/
COPY tsconfig.base.json ./

ARG VITE_CSMS_AUTO_LOGIN=""
RUN VITE_CSMS_AUTO_LOGIN=$VITE_CSMS_AUTO_LOGIN npm run build --workspace=packages/csms

FROM nginx:alpine

COPY --from=build /app/packages/csms/dist /usr/share/nginx/html
COPY packages/csms/nginx.conf /etc/nginx/conf.d/default.conf
COPY packages/csms/docker-runtime-config.sh /docker-entrypoint.d/40-runtime-config.sh
RUN chmod +x /docker-entrypoint.d/40-runtime-config.sh

EXPOSE 7100

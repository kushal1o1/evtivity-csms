{{#if firstName}}<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>Hola {{firstName}},</p>{{/if}}
<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>Un token de carga de tu cuenta fue desactivado:</p>
<p style='color:#1a1a1a;line-height:1.6;margin:0 0 16px 0;'><strong>{{idToken}}</strong> ({{tokenType}})</p>
{{#if reason}}<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>Motivo: {{reason}}</p>{{/if}}
<p style='color:#6b7280;line-height:1.6;margin:0;font-size:14px;'>Puedes reactivarlo desde tu cuenta o contactar soporte.</p>

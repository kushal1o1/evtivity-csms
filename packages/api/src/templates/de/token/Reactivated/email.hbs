{{#if firstName}}<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>Hallo {{firstName}},</p>{{/if}}
<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>Ihr Lade-Token ist wieder aktiv:</p>
<p style='color:#1a1a1a;line-height:1.6;margin:0 0 16px 0;'><strong>{{idToken}}</strong> ({{tokenType}})</p>
<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>Reaktiviert von: {{reactivatedBy}}.</p>
<p style='color:#6b7280;line-height:1.6;margin:0;font-size:14px;'>Falls Sie das nicht waren, kontaktieren Sie den Support.</p>

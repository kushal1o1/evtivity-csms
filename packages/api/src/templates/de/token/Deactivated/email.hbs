{{#if firstName}}<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>Hallo {{firstName}},</p>{{/if}}
<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>Ein Lade-Token auf Ihrem Konto wurde deaktiviert:</p>
<p style='color:#1a1a1a;line-height:1.6;margin:0 0 16px 0;'><strong>{{idToken}}</strong> ({{tokenType}})</p>
{{#if reason}}<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>Grund: {{reason}}</p>{{/if}}
<p style='color:#6b7280;line-height:1.6;margin:0;font-size:14px;'>Sie können es im Konto wieder aktivieren oder den Support kontaktieren.</p>

{{#if firstName}}<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>Hi {{firstName}},</p>{{/if}}
<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>A charging token on your account was deactivated:</p>
<p style='color:#1a1a1a;line-height:1.6;margin:0 0 16px 0;'><strong>{{idToken}}</strong> ({{tokenType}})</p>
{{#if reason}}<p style='color:#4b5563;line-height:1.6;margin:0 0 16px 0;'>Reason: {{reason}}</p>{{/if}}
<p style='color:#6b7280;line-height:1.6;margin:0;font-size:14px;'>You can re-activate it from your Account page or contact support.</p>

FROM node:24-slim

WORKDIR /app

COPY package.json package-lock.json ./
COPY packages/lib/package.json packages/lib/
COPY packages/database/package.json packages/database/
COPY packages/api/package.json packages/api/
COPY packages/ocpp/package.json packages/ocpp/
COPY packages/ocpi/package.json packages/ocpi/
COPY packages/csms/package.json packages/csms/
COPY packages/portal/package.json packages/portal/
COPY packages/codegen/package.json packages/codegen/
COPY packages/css/package.json packages/css/
COPY packages/ocpi-simulator/package.json packages/ocpi-simulator/

RUN npm ci --ignore-scripts

COPY tsconfig.base.json tsconfig.json ./
COPY packages/lib/ packages/lib/
COPY packages/database/ packages/database/
COPY scripts/ scripts/
RUN npx tsc -b --force packages/lib
# Run migrations, verify every SQL file is recorded in __drizzle_migrations,
# then seed the initial admin user. The verifier exits non-zero on a silently-
# skipped migration so docker-compose's `service_completed_successfully` blocks
# dependent services from starting against a stale schema. seed-admin is
# idempotent (ON CONFLICT DO NOTHING) so re-running on every compose up is
# safe -- without it a fresh `docker compose up -d` leaves the DB without an
# admin user and the operator cannot log in.
CMD ["sh", "-c", "cd packages/database && npm run migrate && npm run seed:admin && npm run seed:driver"]
